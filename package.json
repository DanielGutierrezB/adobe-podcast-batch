{
  "name": "adobe-podcast-batch",
  "version": "1.1.10",
  "description": "App de escritorio para procesar audios por lote con Adobe Podcast Enhance Speech",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "electron build/gen-icon.js",
    "dist": "electron-builder --mac",
    "zxp": "bash scripts/build-zxp.sh"
  },
  "author": "Daniel Gutiérrez",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "com.danielgutierrez.adobepodcastbatch",
    "productName": "Adobe Podcast Batch",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "enhance.js",
      "batch.js",
      "premiere-plugin/js/phonos.js",
      "renderer/**/*",
      "build/icon.icns",
      "!node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      { "from": "build/ffmpeg/ffmpeg", "to": "bin/ffmpeg" }
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "Adobe Podcast Batch ${version}"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
