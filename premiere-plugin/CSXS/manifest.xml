<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.danielgutierrez.adobepodcastpremiere"
    ExtensionBundleVersion="1.1.1" ExtensionBundleName="Adobe Podcast Enhance"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.danielgutierrez.adobepodcastpremiere.panel" Version="1.1.1"/>
    <Extension Id="com.danielgutierrez.adobepodcastpremiere.login" Version="1.1.1"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="12.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.danielgutierrez.adobepodcastpremiere.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--disable-web-security</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Adobe Podcast Enhance</Menu>
          <Geometry>
            <Size><Height>560</Height><Width>380</Width></Size>
            <MinSize><Height>420</Height><Width>320</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
    <!-- Ventana de login: modal top-level, así los clics y el teclado van a la página
         de Adobe sin que Premiere intercepte los shortcuts (a diferencia del panel). -->
    <Extension Id="com.danielgutierrez.adobepodcastpremiere.login">
      <DispatchInfo>
        <Resources>
          <MainPath>./login.html</MainPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--disable-web-security</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>false</AutoVisible></Lifecycle>
        <UI>
          <Type>ModalDialog</Type>
          <Menu>Conectar con Adobe</Menu>
          <Geometry>
            <Size><Height>720</Height><Width>560</Width></Size>
            <MinSize><Height>480</Height><Width>420</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
